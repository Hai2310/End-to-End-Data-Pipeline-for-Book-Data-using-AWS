{"name": "Lionel Giles", "bio": {"type": "/type/text", "value": "Lionel Giles was a British Sinologist, writer, and philosopher. Lionel Giles served as assistant curator at the British Museum and Keeper of the Department of Oriental Manuscripts and Printed Books. He is most notable for his 1910 translations of *The Art of War* by Sun Tzu and *The Analects of Confucius*."}, "source_records": ["bwb:9781707264179", "bwb:9781698078557", "amazon:1680920537", "bwb:9798610506890", "amazon:1789871794", "promise:bwb_daily_pallets_2022-03-17", "bwb:9798711903796", "promise:bwb_daily_pallets_2023-11-09:O9-ASL-527", "bwb:9781019614624", "bwb:9781014557056", "bwb:9781477449776"], "type": {"key": "/type/author"}, "personal_name": "Giles, Lionel", "death_date": "22 January 1958", "remote_ids": {"isni": "0000000081042341", "goodreads": "399312", "librarything": "gileslionel", "viaf": "24988122", "project_gutenberg": "5101", "wikidata": "Q59188", "lc_naf": "n83044370", "librivox": "6441", "opac_sbn": "SBLV002528"}, "birth_date": "29 December 1875", "alternate_names": ["翟林奈", "Lionel Tyler Giles", "Giles Lionel", "Lionel 1875-1958 Giles"], "photos": [13814382], "key": "/authors/OL2690004A", "latest_revision": 7, "revision": 7, "created": {"type": "/type/datetime", "value": "2008-04-29T13:35:46.876380"}, "last_modified": {"type": "/type/datetime", "value": "2025-10-30T20:29:03.157212"}}
